<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  SBE Schema 示例：定义一个简单的交易消息协议。

  SBE（Simple Binary Encoding）工作原理：
  1. 在这个 XML Schema 中定义消息结构
  2. 用 SbeTool 从 Schema 生成 Java Encoder/Decoder 类
  3. 生成的类是 Flyweight 模式——直接在 buffer 上按偏移读写，零拷贝零分配

  运行 SbeTool 生成代码的命令：
  java -Dsbe.output.dir=src/main/java \
       -Dsbe.target.language=Java \
       -jar sbe-all-1.37.1.jar \
       src/main/resources/sample/trading-codecs.xml
-->
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="io.aeron.samples.sbe.codecs"
                   id="200"
                   version="1"
                   semanticVersion="1.0"
                   description="Sample trading message codecs for Aeron SBE demo."
                   byteOrder="littleEndian">
    <types>
        <!-- SBE 标准 MessageHeader：每条消息前 8 字节，标识消息类型和长度 -->
        <composite name="messageHeader" description="Message identifiers and length of message root.">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId"  primitiveType="uint16"/>
            <type name="schemaId"    primitiveType="uint16"/>
            <type name="version"     primitiveType="uint16"/>
        </composite>

        <!-- 变长 ASCII 字符串编码 -->
        <composite name="varAsciiEncoding" description="Variable length ASCII string.">
            <type name="length"  primitiveType="uint32" maxValue="1073741824"/>
            <type name="varData" primitiveType="uint8" length="0" characterEncoding="US-ASCII"/>
        </composite>

        <!-- 订单方向枚举 -->
        <enum name="Side" encodingType="uint8" description="Order side.">
            <validValue name="BUY"  description="Buy order.">0</validValue>
            <validValue name="SELL" description="Sell order.">1</validValue>
        </enum>

        <!-- 订单类型枚举 -->
        <enum name="OrderType" encodingType="uint8" description="Order type.">
            <validValue name="MARKET" description="Market order.">0</validValue>
            <validValue name="LIMIT"  description="Limit order.">1</validValue>
        </enum>
    </types>

    <!--
      消息定义：NewOrder（新订单）
      templateId=1，生成 NewOrderEncoder / NewOrderDecoder
    -->
    <sbe:message name="NewOrder" id="1" description="Submit a new order.">
        <field name="orderId"   id="1" type="int64"     description="Unique order identifier."/>
        <field name="accountId" id="2" type="int64"     description="Account identifier."/>
        <field name="price"     id="3" type="int64"     description="Price in cents (e.g. 12345 = $123.45)."/>
        <field name="quantity"  id="4" type="int32"     description="Order quantity."/>
        <field name="side"      id="5" type="Side"      description="Buy or Sell."/>
        <field name="orderType" id="6" type="OrderType" description="Market or Limit."/>
        <data  name="symbol"    id="7" type="varAsciiEncoding" description="Trading symbol (e.g. AAPL)."/>
    </sbe:message>

    <!--
      消息定义：ExecutionReport（成交回报）
      templateId=2，生成 ExecutionReportEncoder / ExecutionReportDecoder
    -->
    <sbe:message name="ExecutionReport" id="2" description="Execution report for a filled order.">
        <field name="orderId"     id="1" type="int64"  description="Original order identifier."/>
        <field name="execId"      id="2" type="int64"  description="Execution identifier."/>
        <field name="filledPrice" id="3" type="int64"  description="Filled price in cents."/>
        <field name="filledQty"   id="4" type="int32"  description="Filled quantity."/>
        <field name="side"        id="5" type="Side"   description="Buy or Sell."/>
        <data  name="symbol"      id="6" type="varAsciiEncoding" description="Trading symbol."/>
    </sbe:message>

</sbe:messageSchema>
